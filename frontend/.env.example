# ─────────────────────────────────────────────
#  משתני סביבה — Frontend (Vite)
#  העתיקו לקובץ .env ומלאו לפני build לפרודקשן.
# ─────────────────────────────────────────────

# API (אופציונלי — בפרודקשן Nginx מנתב /api/)
# VITE_API_URL=

# תשלומים — מלאו לפחות אחד מ: Bit (מספר/קישור) או PayBox לפני השקה
# אל תשאירו קישור לדוגמה — רק פרטים אמיתיים של חסדי המלך
VITE_PAYBOX_LINK=
VITE_BIT_NUMBER=
VITE_BIT_LINK=
VITE_PAYPAL_LINK=

# פרטי בנק (העברה בנקאית) — אופציונלי
VITE_BANK_NAME=
VITE_BANK_BRANCH=
VITE_BANK_ACCOUNT=
VITE_BANK_HOLDER=חסדי המלך
