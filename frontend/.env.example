# ─────────────────────────────────────────────
#  משתני סביבה — Frontend (Vite)
#  העתיקו לקובץ .env ומלאו לפני build לפרודקשן.
# ─────────────────────────────────────────────

# API (אופציונלי — בפרודקשן Nginx מנתב /api/)
# VITE_API_URL=

# תשלומים — מלאו כשמקבלים את הפרטים האמיתיים
VITE_PAYBOX_LINK=https://payboxapp.page.link/WXV7
VITE_BIT_NUMBER=
VITE_PAYPAL_LINK=

# פרטי בנק (העברה בנקאית)
VITE_BANK_NAME=
VITE_BANK_BRANCH=
VITE_BANK_ACCOUNT=
VITE_BANK_HOLDER=חסדי המלך
