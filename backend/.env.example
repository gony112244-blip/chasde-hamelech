# ─────────────────────────────────────────────
#  קובץ דוגמה למשתני סביבה — חסדי המלך (Backend)
#  העתיקו לקובץ בשם .env ומלאו את הערכים האמיתיים.
#  הקובץ .env עצמו לא נשמר בגיט (ראו .gitignore).
# ─────────────────────────────────────────────

# שרת
PORT=3002
# בפרודקשן הגדירו production כדי להפעיל הגנות אבטחה (CSP):
NODE_ENV=production

# ניהול — חובה! לפחות 8 תווים, אחרת השרת לא יעלה.
ADMIN_PASSWORD=שנו-לסיסמה-חזקה

# מקורות נוספים ל-CORS (אם צריך), מופרדים בפסיק
# CORS_EXTRA_ORIGINS=

# בסיס נתונים (PostgreSQL)
DB_USER=postgres
DB_HOST=127.0.0.1
DB_NAME=chasde_hamelech
DB_PASSWORD=
DB_PORT=5432
# PG_POOL_MAX=20

# מייל (Gmail) — להתראות למנהל. השאירו ריק כדי לכבות.
EMAIL_USER=
EMAIL_PASS=
# ADMIN_EMAIL=   # אם ריק — נשלח ל-EMAIL_USER

# תרגום אוטומטי (DeepL) — אופציונלי
# DEEPL_API_KEY=

# ─────────────────────────────────────────────
#  התראות וואטסאפ (אופציונלי) — תשתית מוכנה לחיבור
#  כברירת מחדל מושבת. להפעלה: WHATSAPP_ENABLED=true
#  ובחירת ספק אחד מתוך: twilio | meta | callmebot | webhook
# ─────────────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=
# מספר היעד בפורמט בינלאומי (ספרות בלבד), למשל: 9725XXXXXXXX
WHATSAPP_TO=

# ── אפשרות 1: Twilio WhatsApp ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=14155238886   # מספר ה-WhatsApp של Twilio (ספרות בלבד)

# ── אפשרות 2: Meta WhatsApp Cloud API ──
# WHATSAPP_PHONE_ID=
# WHATSAPP_TOKEN=

# ── אפשרות 3: CallMeBot (חינמי ופשוט) ──
# CALLMEBOT_APIKEY=

# ── אפשרות 4: Webhook גנרי (Green API / מותאם) ──
# WHATSAPP_WEBHOOK_URL=
# WHATSAPP_WEBHOOK_TOKEN=
